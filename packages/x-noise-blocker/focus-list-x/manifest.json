{
    "manifest_version": 3,
    "name": "FocusList for X",
    "version": "1.0",
    "description": "Intercepts X.com navigation and redirects to a specific list, while hiding distractive elements.",
    "permissions": [
        "webNavigation",
        "tabs"
    ],
    "host_permissions": [
        "*://x.com/*",
        "*://twitter.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://x.com/*",
                "*://twitter.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_start"
        }
    ]
}